{
  "name": "techin517",
  "build": {
    "dockerfile": "./Dockerfile",
    "target": "dev"
  },
  "runArgs": [
    "--privileged",
    "--network=host",
    "--gpus",
    "all",
    "-e",
    "DISPLAY=${localEnv:DISPLAY}",
    "-e",
    "NVIDIA_DRIVER_CAPABILITIES=all",
    "-e",
    "WGPU_BACKEND=gl",
    "-e",
    "LIBUSB_DEBUG=3"
  ],
  "workspaceMount": "source=${localWorkspaceFolder},target=/home/ubuntu/techin517,type=bind",
  "workspaceFolder": "/home/ubuntu/techin517",
  "mounts": [
    "source=/etc/timezone,target=/etc/timezone,type=bind",
    "source=/etc/localtime,target=/etc/localtime,type=bind",
    "source=/tmp/.X11-unix,target=/tmp/.X11-unix,type=bind",
    "source=/dev,target=/dev,type=bind",
    "source=/etc/udev,target=/etc/udev,type=bind",
    "source=/run/udev,target=/run/udev,type=bind,readonly",
    "source=${localWorkspaceFolder}/docker/bash_history.txt,target=/home/ubuntu/.bash_history,type=bind"
  ],
  "postStartCommand": "bash -lc '/home/ubuntu/techin517/docker/setup.sh'",
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "ms-toolsai.jupyter"]
    }
  }
}
